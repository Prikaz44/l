<Window x:Class="App_dem.Windows.MenuEmp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:App_dem.Windows"
        mc:Ignorable="d"
        Title="MenuEmp" Height="150" Width="200">
    <Grid>
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="150"
            >
            <TextBlock Text="Меню" HorizontalAlignment="Center"/>
            <Button Name="btnProducts" Content="Товары" Margin="10"
                    Click="btnProducts_Click"/>
            <Button Name="btnOrders"  Content="Заказы" Margin="10"
                    Click="btnOrders_Click"
                    />
        </StackPanel>
        
    </Grid>
</Window>
