<Window x:Class="App_dem.Windows.ProductsSimple"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:App_dem.Windows"
        mc:Ignorable="d"
        Title="ООО «Обувь»" Height="450" Width="800" Icon="/Assets/Icon.JPG" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="Текущий пользователь: " VerticalAlignment="Center"/>
            <TextBlock Text="" Name="txtCurrentUser" VerticalAlignment="Center"/>
            <Button x:Name="btnExitUser" Content="Выйти" Margin="5" Click="btnExitUser_Click"/>
        </StackPanel>
        <TextBlock Text="Список товаров через ListView" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18"/>


        
        
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <ListView x:Name="lvProducts" 
                  Grid.Row="0"
                  HorizontalAlignment="Center"
                  MinWidth="800"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  SelectionMode="Single"
                  IsTextSearchEnabled="False"
                  VirtualizingPanel.ScrollUnit="Pixel"
                  Background="White">

                <ListView.Resources>
                    <!-- Стиль для контейнера элементов (ListViewItem) -->
                    <Style TargetType="ListViewItem">
                        <!-- Убираем стандартные отступы и рамки -->
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,1,0,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="BorderThickness" Value="0"/>

                        <!-- Стиль для чередующегося фона (аналог AlternatingRowBackground) -->
                        <Style.Resources>
                            <SolidColorBrush x:Key="AlternateRowBackground" Color="LightGray"/>
                        </Style.Resources>

                        <Style.Triggers>
                            <!-- Чередование фона (аналог AlternatingRowBackground) -->
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="LightGray"/>
                            </Trigger>

                            <!-- Эффект при наведении (как в DataGrid) -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFE5E5E5"/>
                                <Setter Property="BorderBrush" Value="Gray"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Trigger>

                            <!-- Стиль для выбранного элемента -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FFDDDDDD"/>
                                <Setter Property="BorderBrush" Value="DarkGray"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <!-- Стиль для разделителя (имитация GridLinesVisibility="Horizontal") -->
                    <Style TargetType="Separator">
                        <Setter Property="Background" Value="DarkGray"/>
                        <Setter Property="Height" Value="0.5"/>
                        <Setter Property="Margin" Value="0,0,0,0"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    </Style>
                </ListView.Resources>

                <!-- Шаблон элемента ListView -->
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Основное содержимое -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Изображение товара -->
                                <Image Source="{Binding FullImagePath}" 
                           Width="45" Height="45" 
                           VerticalAlignment="Center"
                           Margin="5,0,0,0"/>

                                <!-- Информация о товаре -->
                                <Grid Grid.Column="1" Margin="5,5,5,5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Категория и наименование -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Категория_товара}" FontWeight="Bold"/>
                                        <TextBlock Text=" | " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Наименование_товара}" FontWeight="Bold"/>
                                    </StackPanel>

                                    <!-- Описание -->
                                    <StackPanel Grid.Row="1" Margin="0,2,0,0" Orientation="Horizontal">
                                        <TextBlock Text="Описание: "/>
                                        <TextBlock Text="{Binding Описание_товара}" 
                                       TextWrapping="Wrap"
                                       Margin="10,0,5,0"/>
                                    </StackPanel>

                                    <!-- Производитель -->
                                    <StackPanel Grid.Row="2" Margin="0,2,0,0" Orientation="Horizontal">
                                        <TextBlock Text="Производитель: "/>
                                        <TextBlock Text="{Binding Производитель}" 
                                       TextWrapping="Wrap"
                                       Margin="10,0,5,0"/>
                                    </StackPanel>

                                    <!-- Поставщик -->
                                    <StackPanel Grid.Row="3" Margin="0,2,0,0" Orientation="Horizontal">
                                        <TextBlock Text="Поставщик: "/>
                                        <TextBlock Text="{Binding Поставщик}" 
                                       TextWrapping="Wrap"
                                       Margin="10,0,5,0"/>
                                    </StackPanel>

                                    <!-- Цена -->
                                    <StackPanel Grid.Row="4" Margin="0,2,0,0" Orientation="Horizontal">
                                        <TextBlock Text="Цена: "/>
                                        <TextBlock Text="{Binding Цена}" 
                                       TextWrapping="Wrap"
                                       Margin="10,0,5,0"/>
                                    </StackPanel>

                                    <!-- Единица измерения -->
                                    <StackPanel Grid.Row="5" Margin="0,2,0,0" Orientation="Horizontal">
                                        <TextBlock Text="Единица_измерения: "/>
                                        <TextBlock Text="{Binding Единица_измерения}" 
                                       TextWrapping="Wrap"
                                       Margin="10,0,5,0"/>
                                    </StackPanel>

                                    <!-- Количество на складе -->
                                    <StackPanel Grid.Row="6" Margin="0,2,5,0" Orientation="Horizontal">
                                        <TextBlock Text="Количество на складе: "/>
                                        <TextBlock Text="{Binding Кол_во_на_складе}" 
                                       TextWrapping="Wrap"
                                       Margin="10,0,5,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <!-- Горизонтальная линия-разделитель (имитация GridLines) -->
                            <Separator Grid.Row="1" Margin="5,0,5,0"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>


            </ListView>

        </Grid>
            
        
    </Grid>
</Window>
