<Window x:Class="App_dem.Windows.ProductsIC"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:App_dem.Windows"
        xmlns:converters="clr-namespace:App_dem.Converters"
        mc:Ignorable="d"
        Title="ProductsIC" Height="450" Width="800">

    <Window.Resources>
        <converters:DiscountToBackgroundConverter x:Key="DiscountToBackgroundConverter"/>
        <converters:StockToBackgroundConverter x:Key="StockToBackgroundConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с пользователем -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <TextBlock x:Name="txtCurrentUser" VerticalAlignment="Center" Margin="5"/>
            <Button x:Name="btnExitUser" Content="Выйти" Margin="5" Padding="10,5" Click="btnExitUser_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icProducts" Margin="10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray" 
                                BorderThickness="0,0,0,1" Margin="0,0,0,10" Padding="0,0,0,10"
                                Background="{Binding Кол_во_на_складе, Converter={StaticResource StockToBackgroundConverter}}"
                                >
                            
                            <Grid Background="{Binding Действующая_скидка, Converter={StaticResource DiscountToBackgroundConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Image Source="{Binding FullImagePath}" 
                                       Width="150" Height="150" 
                                       VerticalAlignment="Center"
                                       Margin="5,0,0,0"/>

                                <Grid Grid.Column="1" Margin="5,5,5,5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Категория_товара}" FontWeight="Bold"/>
                                        <TextBlock Text=" | " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Наименование_товара}" FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Margin="0,2,0,0" Orientation="Horizontal">
                                        <TextBlock Text="Описание: "/>
                                        <TextBlock Text="{Binding Описание_товара}" 
                                                   TextWrapping="Wrap"
                                                   Margin="10,0,5,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Margin="0,2,0,0" Orientation="Horizontal">
                                        <TextBlock Text="Производитель: "/>
                                        <TextBlock Text="{Binding Производитель}" 
                                                   TextWrapping="Wrap"
                                                   Margin="10,0,5,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Margin="0,2,0,0" Orientation="Horizontal">
                                        <TextBlock Text="Поставщик: "/>
                                        <TextBlock Text="{Binding Поставщик}" 
                                                   TextWrapping="Wrap"
                                                   Margin="10,0,5,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Margin="0,2,0,0" Orientation="Horizontal">
                                        <TextBlock Text="Цена: "/>
                                        <TextBlock Text="{Binding Цена}" 
                                                   TextWrapping="Wrap"
                                                   Margin="10,0,5,0"
                                                   Foreground="Red"
                                                   TextDecorations="Strikethrough"
                                                   />
                                        <TextBlock Text="{Binding Цена_со_скидкой}" 
                                                   TextWrapping="Wrap"
                                                   Margin="15,0,5,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="5" Margin="0,2,0,0" Orientation="Horizontal">
                                        <TextBlock Text="Единица измерения: "/>
                                        <TextBlock Text="{Binding Единица_измерения}" 
                                                   TextWrapping="Wrap"
                                                   Margin="10,0,5,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="6" Margin="0,2,5,0" Orientation="Horizontal">
                                        <TextBlock Text="Количество на складе: "/>
                                        <TextBlock Text="{Binding Кол_во_на_складе}" 
                                                   TextWrapping="Wrap"
                                                   Margin="10,0,5,0"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Name="lblDiscount" Grid.Column="2"
                                               Text="{Binding Действующая_скидка}"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               FontSize="16"
                                               Foreground="{Binding Действующая_скидка}"
                                               />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <!-- Дополнительные элементы управления -->
        </StackPanel>
    </Grid>
</Window>
