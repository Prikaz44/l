<Window x:Class="App_dem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:App_dem"
        mc:Ignorable="d"
        Title="ООО «Обувь» - Авторизация" Height="187" Width="250"
        MinHeight="185" MinWidth="250" Icon="/Assets/Icon.JPG">
    <Grid>
        <TextBox x:Name="txtLogin"
            HorizontalAlignment="Left" Margin="88,39,0,0" 
                 Text="" VerticalAlignment="Top" Width="120"/>
        <Label Content="Логин" 
            HorizontalAlignment="Left" Margin="29,35,0,0" VerticalAlignment="Top"/>
        <PasswordBox x:Name="txtPass"
            HorizontalAlignment="Left" Margin="88,70,0,0" VerticalAlignment="Top" Width="120"/>
        <Label Content="Пароль" HorizontalAlignment="Left" 
               Margin="30,65,0,0" VerticalAlignment="Top"/>
        <Button Name="btnEnter" 
                Content="Войти" HorizontalAlignment="Left" 
                Margin="34,118,0,0" VerticalAlignment="Top" 
                RenderTransformOrigin="0.014,0.578" Width="80"
                Click="btnEnter_Click"/>
        <Button Name="btnGuest"
                Content="Войти гостем" HorizontalAlignment="Left" 
                Margin="127,118,0,0" VerticalAlignment="Top" Width="80"
                Click="btnGuest_Click"/>
    </Grid>
</Window>
