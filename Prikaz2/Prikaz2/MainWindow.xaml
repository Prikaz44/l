<Window x:Class="Prikaz2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Prikaz2"
        mc:Ignorable="d"
        Title="ООО Обувь Авторизация" Height="450" Width="800" Icon="/Assets/Icon.png">
    <Grid>
        <Grid Height="223" Margin="0,0,291,0" VerticalAlignment="Center" HorizontalAlignment="Right" Width="244">
            <TextBox x:Name="txtLogin" Margin="82,0,0,140" TextWrapping="Wrap" Height="33" VerticalAlignment="Bottom" FontFamily="Times New Roman" FontSize="14" BorderBrush="MediumSpringGreen" HorizontalAlignment="Left" Width="146" />

            <PasswordBox x:Name="txtPass" Margin="0,109,16,0" HorizontalAlignment="Right" Width="144" Height="35" VerticalAlignment="Top" BorderBrush="MediumSpringGreen"/>

            <Label Content="Логин" Margin="6,48,179,0" VerticalAlignment="Top" FontFamily="Times New Roman" FontSize="18"/>
            <Label Content="Пароль" Margin="0,110,0,0" VerticalAlignment="Top" FontFamily="Times New Roman" FontSize="18" HorizontalAlignment="Left" Width="68"/>
            
            
            <Button Content="Войти" Height="44" Margin="2,179,0,0" VerticalAlignment="Top" Background="MediumSpringGreen" BorderBrush="Chartreuse" HorizontalAlignment="Left" Width="99" Click="btnEnter_Click"/>
            <Button Content="Войти как гость" HorizontalAlignment="Left" Margin="145,178,0,0" Width="99" Background="MediumSpringGreen" BorderBrush="Chartreuse" Height="44" VerticalAlignment="Top" Click="btnGuest_Click"/>
            
            
            <Label Content="Авторизация" HorizontalAlignment="Left" Margin="77,0,0,0" VerticalAlignment="Top" FontFamily="Times New Roman" FontSize="18"/>

        </Grid>

    </Grid>
</Window>
