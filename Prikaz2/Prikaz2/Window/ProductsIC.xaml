<Window x:Class="Prikaz2.Windows.ProductIC"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Prikaz2.Windows"
        mc:Ignorable="d"
        Title="ProductIC" 
        Height="450" 
        Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с пользователем -->
        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="10">
            <TextBlock Text="Текущий пользователь: " 
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="txtCurrentUser" 
                       VerticalAlignment="Center" 
                       FontWeight="Bold" 
                       Margin="0,0,10,0"/>
            <Button x:Name="btnExitUser" 
                    Content="Выйти" 
                    Padding="10,5" 
                    Click="btnExitUser_Click"/>
        </StackPanel>

        <!-- Заголовок -->
        <TextBlock Grid.Row="1" 
                   Text="Список товаров" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center" 
                   Margin="10"/>

        <!-- ListView с товарами -->
        <ListView Grid.Row="2" 
                  x:Name="lvProducts"
                  Margin="10"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  SelectionMode="Single"
                  Background="White"
                  BorderBrush="LightGray"
                  BorderThickness="1">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,1"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

                    <Style.Triggers>
                        <!-- Чередование фона -->
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="#F5F5F5"/>
                        </Trigger>

                        <!-- Эффект при наведении -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E5F3FF"/>
                        </Trigger>

                        <!-- Выделенный элемент -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#CCE8FF"/>
                            <Setter Property="BorderBrush" Value="#0078D7"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" 
                            BorderThickness="0,0,0,1" 
                            Padding="5">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Изображение товара --><!--
                            <Border Grid.Column="0" 
                                    Width="60" 
                                    Height="60" 
                                    Margin="0,0,10,0"
                                    BorderBrush="LightGray" 
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <Image Source="{Binding FullImagePath}" 
                                       Width="50" 
                                       Height="50"
                                       Stretch="Uniform"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Source" Value="/Images/default_product.png"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FullImagePath}" Value="{x:Null}">
                                                    <Setter Property="Source" Value="/Images/default_product.png"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FullImagePath}" Value="">
                                                    <Setter Property="Source" Value="/Images/default_product.png"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Border>-->

                            <!-- Информация о товаре -->
                            <StackPanel Grid.Column="1" 
                                        VerticalAlignment="Center"
                                        Margin="5">

                                <!-- Категория и наименование -->
                                <TextBlock>
                                    <Run Text="{Binding Категория_товара, Mode=OneWay}" 
                                         FontWeight="Bold" 
                                         FontSize="14"/>
                                    <Run Text=" | " 
                                         FontWeight="Bold"/>
                                    <Run Text="{Binding Наименование_товара, Mode=OneWay}" 
                                         FontWeight="Bold" 
                                         FontSize="14"/>
                                </TextBlock>

                                <!-- Описание -->
                                <TextBlock TextWrapping="Wrap" 
                                           Margin="0,3,0,0"
                                           Foreground="Gray">
                                    <Run Text="Описание: "/>
                                    <Run Text="{Binding Описание_товара, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Производитель и Поставщик -->
                                <WrapPanel Margin="0,3,0,0">
                                    <TextBlock Foreground="Gray">
                                        <Run Text="Производитель: "/>
                                        <Run Text="{Binding Производитель, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Margin="10,0,0,0" Foreground="Gray">
                                        <Run Text="Поставщик: "/>
                                        <Run Text="{Binding Поставщик, Mode=OneWay}"/>
                                    </TextBlock>
                                </WrapPanel>

                                <!-- Цена и единица измерения -->
                                <WrapPanel Margin="0,3,0,0">
                                    <TextBlock FontWeight="Bold" 
                                               Foreground="#0078D7"
                                               FontSize="16">
                                        <Run Text="{Binding Цена, Mode=OneWay, StringFormat={}{0:F2}}"/>
                                        <Run Text=" ₽"/>
                                    </TextBlock>
                                    <TextBlock Margin="15,0,0,0" 
                                               VerticalAlignment="Center"
                                               Foreground="Gray">
                                        <Run Text="Ед. изм: "/>
                                        <Run Text="{Binding Единица_измерения, Mode=OneWay}"/>
                                    </TextBlock>
                                </WrapPanel>

                                <!-- Количество на складе -->
                                <TextBlock Margin="0,3,0,0" 
                                           Foreground="Gray">
                                    <Run Text="На складе: "/>
                                    <Run Text="{Binding Кол_во_на_складе, Mode=OneWay}"/>
                                    <Run Text=" шт."/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>